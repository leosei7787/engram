# Python
__pycache__/
*.py[cod]
*.pyo
.Python
*.egg-info/
dist/
build/
.eggs/
.venv/
venv/
env/

# Memory store — folder structure is tracked (.gitkeep); data files are not
memory-store/**
!memory-store/**/
!memory-store/**/.gitkeep

# Knowledge base — same rule
knowledge-base/**
!knowledge-base/**/
!knowledge-base/**/.gitkeep

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Editor
.idea/
.vscode/
*.swp
*.swo

# Logs
*.log

# Raw data files (only exist in user's local instance)
*.jsonl

# Tests — kept locally for development but never committed; their fixtures
# tend to gather real names / accounts / emails from whatever the developer
# is working on, and GitHub's code-search index surfaces every historical
# blob. Easier rule: don't sync them.
tests/
